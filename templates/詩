<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>墨影留白 - 詩詞互動</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- 使用思源宋體，最適合展現中國詩詞的優雅 -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        body {
            font-family: 'Noto Serif TC', serif;
            /* 預設紙張底色 */
            background-color: #F4F1EA; 
            margin: 0;
            padding: 0;
            overflow-x: auto;
            overflow-y: hidden;
            /* 讓滾動條變得優雅 */
            scrollbar-width: thin;
            scrollbar-color: #8c7b6d transparent;
        }

        /* 新增：自訂背景圖層，設定 50% 透明度 */
        .custom-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background-image: url('https://share.google/UHL1pr60yKTyyfTNp');
            background-size: cover;
            background-position: center;
            opacity: 0.5;
            z-index: -2;
        }

        /* 宣紙般的霧面遮罩，營造出國畫「留白」與仙氣感 */
        .ink-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: linear-gradient(135deg, rgba(244, 241, 234, 0.92) 0%, rgba(220, 215, 205, 0.8) 100%);
            backdrop-filter: blur(3px);
            z-index: -1;
        }

        /* 詩詞容器：直書、由右至左 */
        .poem-container {
            writing-mode: vertical-rl;
            text-orientation: upright;
            height: 80vh;
            margin: 10vh auto;
            padding: 0 10vw; /* 左右留白 */
            color: #2c2c2c;
            display: flex;
            align-items: flex-start;
            gap: 3rem; /* 行距 */
        }

        /* 單行詩句 */
        .poem-line {
            display: inline-flex;
            flex-direction: column;
            gap: 0.5rem; /* 字距 */
        }

        /* 單個字 */
        .char {
            display: inline-block;
            font-size: 3.5rem; /* 文字要大且優雅 */
            font-weight: 300;
            cursor: default;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.1);
            /* 消散與回歸的動畫過渡：2秒的漸變，看起來像霧氣 */
            transition: opacity 2s cubic-bezier(0.4, 0, 0.2, 1), 
                        filter 2s cubic-bezier(0.4, 0, 0.2, 1), 
                        transform 2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* 字消失時的狀態 */
        .char.hidden {
            opacity: 0;
            filter: blur(8px);
            /* 移除 transform 位移，確保字在原位消失，不影響排版 */
        }

        /* 新增：詩詞輸入框區域 */
        .input-panel {
            position: fixed;
            bottom: 2rem;
            right: 6rem;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
            opacity: 0.4;
            transition: opacity 0.3s;
            z-index: 10;
        }
        .input-panel:hover {
            opacity: 1;
        }
        .input-panel textarea {
            background: rgba(244, 241, 234, 0.7);
            border: 1px solid #8c7b6d;
            color: #2c2c2c;
            font-family: 'Noto Serif TC', serif;
            padding: 0.5rem;
            border-radius: 4px;
            outline: none;
            resize: none;
            width: 250px;
        }
        .input-panel button {
            background: #a83b3b;
            color: #F4F1EA;
            border: none;
            padding: 0.3rem 1rem;
            border-radius: 4px;
            cursor: pointer;
            font-family: 'Noto Serif TC', serif;
            font-weight: 600;
        }

        /* 中國風印章裝飾 */
        .seal {
            position: fixed;
            bottom: 2rem;
            left: 2rem;
            width: 50px;
            height: 50px;
            border: 2px solid #a83b3b;
            color: #a83b3b;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.2rem;
            font-weight: 600;
            border-radius: 4px;
            writing-mode: vertical-rl;
            opacity: 0.7;
            cursor: pointer;
            transition: opacity 0.3s, transform 0.3s;
            user-select: none;
        }

        .seal:hover {
            opacity: 1;
            transform: scale(1.05);
        }

        /* RWD 微調 */
        @media (max-width: 768px) {
            .char { font-size: 2.5rem; }
            .poem-container { height: 70vh; margin: 15vh auto; gap: 2rem; }
        }
    </style>
</head>
<body>

    <!-- 新增背景圖層 -->
    <div class="custom-bg"></div>

    <!-- 背景霧面遮罩 -->
    <div class="ink-overlay"></div>

    <!-- 詩詞內容區 -->
    <div class="poem-container" id="poem-box">
        <!-- JS 會動態將文字注入這裡 -->
    </div>

    <!-- 右下角印章（點擊可重置全部文字） -->
    <div class="seal" onclick="resetAll()" title="重新凝聚">忘歸</div>

    <!-- 新增：輸入框區塊 -->
    <div class="input-panel">
        <textarea id="custom-poem-input" rows="4" placeholder="在此輸入你的心緒...&#10;每行請用換行隔開"></textarea>
        <button onclick="applyNewPoem()">提筆入夢</button>
    </div>

    <script>
        // 這裡選用納蘭性德的詩詞，訴說感情中初見的美好與易變的無奈
        // 配合文字會消失的特性，非常切合「等閒變卻故人心」的意境
        let poemText = [
            "人生若只如初見",
            "何事秋風悲畫扇",
            "等閒變卻故人心",
            "卻道故人心易變"
        ];

        const container = document.getElementById('poem-box');
        let charElements = [];

        // 初始化網頁：將詩句拆解成單個字，並包裝成 span 標籤
        function initPoem() {
            // 每次初始化前先清空容器，避免重複疊加
            container.innerHTML = '';
            charElements = [];

            poemText.forEach(line => {
                const lineDiv = document.createElement('div');
                lineDiv.className = 'poem-line';
                
                // 拆解每個字
                const chars = line.split('');
                chars.forEach(char => {
                    const charSpan = document.createElement('span');
                    charSpan.className = 'char';
                    charSpan.textContent = char;
                    
                    // 加入滑鼠互動事件 (Touch 事件也支援，方便手機操作)
                    charSpan.addEventListener('mouseenter', () => vanishChar(charSpan));
                    charSpan.addEventListener('touchstart', (e) => {
                        e.preventDefault(); // 避免手機點擊引發其他行為
                        vanishChar(charSpan);
                    }, { passive: false });

                    lineDiv.appendChild(charSpan);
                    charElements.push(charSpan);
                });
                container.appendChild(lineDiv);
            });
        }

        // 核心邏輯：讓字消失，並設定計時器讓它回來
        function vanishChar(element) {
            // 如果已經在隱藏狀態，就不重複執行
            if (element.classList.contains('hidden')) return;

            // 加上 hidden class，觸發 CSS 漸變讓它消失
            element.classList.add('hidden');

            // 設定 4 秒後自動回來 (4000 毫秒)
            setTimeout(() => {
                element.classList.remove('hidden');
            }, 4000);
        }

        // 印章按鈕功能：一鍵讓所有字立刻浮現
        function resetAll() {
            charElements.forEach(char => {
                char.classList.remove('hidden');
            });
        }

        // 新增：寫入新詩詞的功能
        function applyNewPoem() {
            const inputVal = document.getElementById('custom-poem-input').value;
            if (!inputVal.trim()) return; // 空白就不處理
            
            // 依據換行符號切割成陣列，並過濾掉空行
            poemText = inputVal.split('\n').filter(line => line.trim() !== '');
            
            // 重新初始化
            initPoem();
        }

        // 載入完畢後執行
        window.onload = initPoem;
    </script>

</body>
</html>
